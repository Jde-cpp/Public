{
	"settings": {
		"window.title": "Access",
		"name": "access",
		"target": "Jde.Access.Tests",
		"subDir": "libs/${config:name}",
		"buildTarget": "Debug",
		"cmake.sourceDirectory": "${workspaceFolder:tests}/../../..",
		"cmake.buildDirectory": "${command:jde.repoBuildDir}",
	},
	"tasks": {
		"version": "2.0.0",
		"tasks": [
			{
				"label": "clean",
				"type": "shell",
				"command": "tput reset; cd ${config:cmake.buildDirectory}; cmake --build . --target clean;",
			},
			{
				"label": "run",
				"type": "shell",
				"dependsOn": ["build", "clearTerminal"],
				"command": "./${config:target}",
				"args": ["-tests", "-settings=${workspaceFolder:tests}/config/Access.Tests.jsonnet"],
				"options": {
					"cwd": "${config:cmake.buildDirectory}/runtime",
				}
			}
		]
	},
	"launch": {
		"version": "0.2.0",
		"configurations": [{
			"name": "Debug",
			"type": "lldb",
			"request": "launch",
			"program": "${config:cmake.buildDirectory}/${config:subDir}/tests/${config:target}",
			"args": ["-tests", "-settings=${workspaceFolder:tests}/config/Access.Tests.jsonnet"],
			"env": {
				"RUNTIME_DIR": "${config:cmake.buildDirectory}/runtime",
				"REPO_SOURCE_DIR": "${config:cmake.sourceDirectory}",
				"REPO_BUILD_DIR": "${config:cmake.buildDirectory}"
			},
			"cwd": "${config:cmake.buildDirectory}/runtime",
			"preLaunchTask": "build"
		},
		{
			"name": "Release",
			"type": "lldb",
			"request": "launch",
			"program": "${env:JDE_DIR}/Release/g++-14/libs/access/tests/Jde.Access.Tests",
			"args": [
				"-settings=${env:JDE_DIR}/libs/access/tests/config/Access.Tests.jsonnet",
				"-tests"
			],
			"cwd": "${env:JDE_DIR}/Release/g++-14/libs/access/tests",
		}]
	},
	"folders": [
		{
			"path": "config"
		},
		{
			"path": "tests"
		},
		{
			"path": "src",
			"name": "access"
		},
		{
			"path": "../ql",
			"name": "ql"
		},
		{
			"path": "../db/src",
			"name": "db"
		},
		{
			"path": "../../include/jde",
			"name": "headers"
		},
		{
			"path": "../../build",
			"name": "pbuild"
		},
		{
			"path": "../fwk/src",
			"name": "fwk"
		},
		{
			"path": "../db/drivers/mysql",
			"name": "MySql"
		},
		{
			"path": "../db/drivers/mysql",
			"name": "MySqlOld"
		}
	],
}
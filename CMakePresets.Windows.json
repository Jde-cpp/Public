{
	"version": 9,
	"include": [
		"CMakePresets.common.json"
	],
	"configurePresets": [
		{
			"name": "win",
			"hidden": true,
			"inherits": "common",
			"environment": {
				"cxxFlags": "-DWIN32_LEAN_AND_MEAN"
			},
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "$env{buildType}",
				"CMAKE_GENERATOR_PLATFORM": "x64",
				"CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
			}
		},
		{
			"name": "win-clang",
			"hidden": true,
			"inherits": [
				"clang",
				"win"
			],
			"generator": "Ninja",
			"cacheVariables": {
				"CMAKE_GENERATOR_PLATFORM": null,
				"CMAKE_CXX_FLAGS": "$env{cxxFlags} -DBOOST_STACKTRACE_USE_WINDBG",
				"CMAKE_CXX_FLAGS_DEBUG": "$env{cxxFlagsDebug}",
				"CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=lld -Wl,/ignore:longsections -ldbgeng",
				"CMAKE_SHARED_LINKER_FLAGS": "-fuse-ld=lld -Wl,/ignore:longsections -ldbgeng",
				"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
				"VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
				"VCPKG_INSTALLED_DIR": "$env{VCPKG_ROOT}/installed"
			}
		},
		{
			"name": "win-lldb",
			"hidden": true,
			"environment": {
				"cxxFlagsDebugInfo": "-gdwarf-4"
			},
			"cacheVariables": {}
		},
		{
			"name": "win-clang-debug",
			"hidden": true,
			"inherits": [
				"win-clang",
				"debug"
			],
			"binaryDir": "$env{JDE_BUILD_DIR}/clang++/${sourceDirName}/debug"
		},
		{
			"name": "win-clang-release",
			"hidden": true,
			"inherits": [
				"win-clang",
				"release"
			],
			"binaryDir": "$env{JDE_BUILD_DIR}/clang++/${sourceDirName}/release"
		},
		{
			"name": "win-clang-debug-jde",
			"inherits": [
				"win-clang-debug",
				"clang-jde",
				"win-lldb"
			],
			"cacheVariables": {
				"CMAKE_CXX_FLAGS": "$env{cxxFlags} $env{cxxFlagsDebugInfo} -DBOOST_STACKTRACE_USE_WINDBG"
			}
		},
		{
			"name": "win-repos",
			"hidden": true,
			"inherits": [
				"repos"
			],
			"cacheVariables": {
				"CMAKE_HAVE_LIBC_PTHREAD": "OFF",
				"CMAKE_HAVE_PTHREADS_CREATE": "OFF",
				"CMAKE_HAVE_PTHREAD_CREATE": "OFF",
				"THREADS_HAVE_PTHREAD_ARG": "OFF",
				"HAVE_SHLLOAD": "OFF"
			}
		},
		{
			"name": "win-clang-debug-repos",
			"inherits": [
				"win-clang-debug",
				"win-repos"
			],
			"binaryDir": "$env{JDE_BUILD_DIR}/clang++-repos/debug"
		},
		{
			"name": "win-clang-release-repos",
			"inherits": [
				"win-clang-release",
				"win-repos"
			],
			"binaryDir": "$env{JDE_BUILD_DIR}/clang++-repos/release"
		}
	]
}

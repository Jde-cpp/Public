{
	"version": 8,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 28,
		"patch": 3
	},
	"configurePresets": [
		{
			"name": "common",
			"hidden": true,
			"environment": {
				"installRoot": "$env{REPO_DIR}/install/$env{CXX}",
				"multiInstallPrefix": "$env{installRoot}/multi"
			},
			"cacheVariables":{
				"CMAKE_CXX_STANDARD": "26",
				"JDE_VERSION": "2026.07.01",
				"MIN_REQ_CMAKE_VERSION": "3.28.3",
				"MULTI_INSTALL_PREFIX": "$env{multiInstallPrefix}",
				"SPDLOG_FMT_EXTERNAL": "ON"
			}
		},
		{
			"name": "repos",
			"hidden": true,
			"cacheVariables":{
				"TYPE_INSTALL_PREFIX": "$env{installRoot}/$env{buildType}",
				"jde_REPOS": true,
				"jde_TESTS": false,
				"jde_APPS": false
			}
		},
		{
			"name": "debug",
			"hidden": true,
			"environment":{
				"buildType": "Debug"
			},
			"cacheVariables": {
				"CMAKE_INSTALL_PREFIX": "$env{installRoot}/Debug",
				"CMAKE_PREFIX_PATH": "$env{installRoot}/Debug;$env{multiInstallPrefix}"
			}
		},
		{
			"name": "relWithDebInfo",
			"hidden": true,
			"environment":{
				"buildType": "RelWithDebInfo"
			},
			"cacheVariables": {
				"CMAKE_INSTALL_PREFIX": "$env{installRoot}/RelWithDebInfo",
				"CMAKE_PREFIX_PATH": "$env{installRoot}/RelWithDebInfo;$env{multiInstallPrefix}"
			}
		},
    {
      "name": "win",
      "inherits": "common",
			"environment":{
				"cxxFlags": "-DWIN32_LEAN_AND_MEAN"
			},
			"cacheVariables":{
				"CMAKE_GENERATOR_PLATFORM": "x64",
				"CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
			}
		},
		{
			"name": "linux",
			"inherits": "common",
			"cacheVariables":{
				"CMAKE_BUILD_TYPE": "$env{buildType}",
				"LIBXML2_INCLUDE_DIR": "/usr/include/libxml2"
			}
		},

		{
			"name": "linux-debug",
			"inherits": ["linux", "debug"],
			"cacheVariables":{
				"CMAKE_CXX_FLAGS_DEBUG": "-ggdb -fsanitize=address -fsanitize=leak -fno-omit-frame-pointer -D_GLIBCXX_DEBUG=ON -static-libstdc++ -static-libasan -lrt"
			}
		},
		{
			"name": "linux-relWithDebInfo",
			"inherits": ["linux", "relWithDebInfo"]
		},
		{
			"name": "linux-jde",
			"hidden": true,
			"inherits": ["linux"],
			"cacheVariables": {
				"Boost_USE_STATIC_LIBS": true,
				"BOOST_VERSION": "1.91.0"
			}
		},
		{
			"name": "linux-jde-relWithDebInfo",
			"inherits": ["linux-jde","relWithDebInfo"],
			"environment": {
				"OPTIMIZATION_LEVEL": "O3"
			},
			"cacheVariables": {
			}
		},
		{
			"name": "clang-jde",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": true,
				"EXCLUDED_WARNINGS": "-Wno-unknown-pragmas;-Wno-missing-field-initializers;-Wno-unqualified-std-cast-call;-Wno-language-extension-token;-Wno-dollar-in-identifier-extension"
			}
		},
		{
			"name": "clang-linux",
			"inherits": ["clang","linux"],
			"cacheVariables":{
				"CMAKE_C_COMPILER": "clang",
				"CMAKE_CXX_COMPILER": "clang++",
				"CMAKE_CXX_FLAGS": "-stdlib=libc++",
				"CMAKE_CXX_FLAGS_DEBUG": "$env{cxxFlagsDebug} -glldb -static-libasan -fsanitize=leak -fsanitize=address -fno-omit-frame-pointer -fexperimental-library -D_LIBCPP_ENABLE_EXPERIMENTAL",
				"CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++ -fuse-ld=lld",
				"CMAKE_SHARED_LINKER_FLAGS": "-stdlib=libc++ -fuse-ld=lld"
			}
		},
    {
      "name": "clang",
      "environment": {
        "CC": "clang",
        "CXX": "clang++"
      },
			"cacheVariables":{
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
			}
    },
    {
      "name": "win-clang",
			"inherits": ["clang","win"],
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables":{
        "CMAKE_GENERATOR_PLATFORM": null,
				"CMAKE_CXX_FLAGS_DEBUG": "$env{cxxFlagsDebug}",
				"CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=lld -Wl,/ignore:longsections",
				"CMAKE_SHARED_LINKER_FLAGS": "-fuse-ld=lld -Wl,/ignore:longsections",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "VCPKG_INSTALLED_DIR": "$env{VCPKG_ROOT}/installed"
      }
    },
		{
			"name": "linux-clang",
			"inherits": ["clang", "linux"],
			"hidden": true,
			"cacheVariables":{
				"CMAKE_CXX_FLAGS": "-stdlib=libc++",
				"CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++ -fuse-ld=lld",
				"CMAKE_SHARED_LINKER_FLAGS": "-stdlib=libc++ -fuse-ld=lld",
        "CMAKE_CXX_FLAGS_DEBUG": "-glldb -stdlib=libc++ -fsanitize=address -fsanitize=leak -fno-omit-frame-pointer -static-libasan -fexperimental-library -D_LIBCPP_ENABLE_EXPERIMENTAL"

			}
		},
		{
			"name": "win-lldb",
			"hidden": true,
			"environment": {
				"cxxFlagsDebugInfo": "-gdwarf-4"
			},
			"cacheVariables": {
			}
		},
		{
			"name": "linux-clang-debug",
			"inherits": ["linux-clang", "debug"]
		},
		{
			"name": "win-clang-debug",
			"hidden": true,
			"inherits": ["win-clang", "debug"],
			"binaryDir": "$env{JDE_BUILD_DIR}/clang++"
		},
		{
			"name": "linux-clang-debug-jde",
			"inherits": ["linux-clang-debug", "clang-jde"],
			"cacheVariables":{
			}
		},
		{
			"name": "win-clang-debug-jde",
			"inherits": ["win-clang-debug", "clang-jde", "win-lldb"],
			"cacheVariables": {
				"CMAKE_CXX_FLAGS": "$env{cxxFlags} $env{cxxFlagsDebugInfo}"
			}
		},
		{
			"name": "linux-repos",
			"hidden": true,
			"inherits": ["repos"],
			"cacheVariables": {
				"LIBXML2_LIBDIR": "/usr/lib/x86_64-linux-gnu",
				"TYPE_INSTALL_PREFIX": "$env{installRoot}/$env{buildType}"
			}
		},
		{
			"name": "win-repos",
			"hidden": true,
			"inherits": ["repos"],
			"cacheVariables": {
				"CMAKE_HAVE_LIBC_PTHREAD": "OFF",
				"CMAKE_HAVE_PTHREADS_CREATE": "OFF",
				"CMAKE_HAVE_PTHREAD_CREATE": "OFF",
				"THREADS_HAVE_PTHREAD_ARG": "OFF",
				"HAVE_SHLLOAD": "OFF"
			}
		},
		{
			"name": "win-clang-debug-repos",
			"inherits": ["win-clang-debug", "win-repos"]
		}
	],
	"buildPresets": [
		{
			"name": "linux-debug",
			"description": "",
			"displayName": "",
			"configurePreset": "linux-debug"
		}
	],
	"testPresets": [
		{
			"name": "linux-debug",
			"description": "",
			"displayName": "",
			"configurePreset": "linux-debug"
		}
	]
}

{
	"version": 8,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 28,
		"patch": 3
	},
	"configurePresets": [
		{
			"name": "common",
			"hidden": true,
			"environment": {
				"installRoot": "$env{REPO_DIR}/install/$env{CXX}",
				"multiInstallPrefix": "$env{installRoot}/multi"
			},
			"cacheVariables":{
				"CMAKE_CXX_STANDARD": "26",
				"JDE_VERSION": "2026.06.01",
				"MIN_REQ_CMAKE_VERSION": "3.28.3",
				"MULTI_INSTALL_PREFIX": "$env{multiInstallPrefix}",
				"SPDLOG_FMT_EXTERNAL": "ON",
				"TYPE_INSTALL_PREFIX": "$env{installRoot}/$env{buildType}",
				"CMAKE_INSTALL_PREFIX": "$env{installRoot}/$env{buildType}",
				"CMAKE_PREFIX_PATH": "$env{installRoot}/$env{buildType};$env{multiInstallPrefix}"
			}
		},
		{
			"name": "debug",
			"hidden": true,
			"environment":{
				"buildType": "Debug"
			}
		},
		{
			"name": "relWithDebInfo",
			"hidden": true,
			"environment":{
				"buildType": "RelWithDebInfo"
			}
		},
    {
      "name": "win",
      "inherits": "common",
			"cacheVariables":{
				"CMAKE_GENERATOR_PLATFORM": "x64",
				"CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
			}
		},
		{
			"name": "linux",
			"inherits": "common",
			"environment": {
				"CC": "gcc",
				"CXX": "g++-15"
			},
			"cacheVariables":{
				"CMAKE_BUILD_TYPE": "$env{buildType}",
				"CMAKE_CXX_COMPILER": "g++-15",
				"CMAKE_C_COMPILER": "gcc-15",
				"CMAKE_CXX_FLAGS": "-Wno-unknown-pragmas -Wno-missing-field-initializers -Wno-changes-meaning",
				"LIBXML2_INCLUDE_DIR": "/usr/include/libxml2",
				"LIBXML2_LIBDIR": "/usr/lib/x86_64-linux-gnu"
			}
		},
		{
			"name": "linux-debug",
			"inherits": ["linux", "debug"],
			"cacheVariables":{
				"CMAKE_CXX_FLAGS_DEBUG": "-ggdb -fsanitize=address -fsanitize=leak -fno-omit-frame-pointer -D_GLIBCXX_DEBUG=ON -static-libstdc++ -static-libasan -lrt"
			}
		},
		{
			"name": "linux-relWithDebInfo",
			"inherits": ["linux", "relWithDebInfo"]
		},
		{
			"name": "linux-jde",
			"hidden": true,
			"inherits": ["linux"],
			"cacheVariables": {
				"Boost_USE_STATIC_LIBS": true,
				"BOOST_VERSION": "1.91.0",
				"EXCLUDED_WARNINGS": "-Wno-unknown-pragmas -Wno-missing-field-initializers -Wno-changes-meaning -Wno-unqualified-std-cast-call"
			}
		},
		{
			"name": "linux-jde-relWithDebInfo",
			"inherits": ["linux-jde","relWithDebInfo"],
			"environment": {
				"OPTIMIZATION_LEVEL": "O3"
			},
			"cacheVariables": {
			}
		},
    {
      "name": "clang",
			"environment": {
				"CC": "clang-22",
				"CXX": "clang++-22"
			},
			"cacheVariables":{
				"CMAKE_C_COMPILER": "clang-22",
				"CMAKE_CXX_COMPILER": "clang++-22",
				"CMAKE_CXX_FLAGS": "-stdlib=libc++",
				"CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++ -fuse-ld=lld",
				"CMAKE_SHARED_LINKER_FLAGS": "-stdlib=libc++ -fuse-ld=lld",
        "CMAKE_CXX_FLAGS_DEBUG": "-glldb -stdlib=libc++ -fsanitize=address -fsanitize=leak -fno-omit-frame-pointer -static-libasan -fexperimental-library -D_LIBCPP_ENABLE_EXPERIMENTAL"
      }
    },
    {
      "name": "clang-win",
      "hidden": true,
      "generator": "Ninja",
      "environment": {
        "CC": "clang",
        "CXX": "clang++"
      },
      "cacheVariables":{
        "CMAKE_GENERATOR_PLATFORM": null,
        "CMAKE_BUILD_TYPE": "$env{buildType}",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS_DEBUG": "-g"
      }
    },
		{
			"name": "win-clang-debug",
			"inherits": ["clang-win", "win", "debug"],
			"binaryDir": "$env{JDE_BUILD_DIR}/clang++-22"
		},
		{
			"name": "linux-clang-debug",
			"inherits": ["linux", "debug", "clang"]
		},
		{
			"name": "linux-clang-jde-debug",
			"inherits": ["linux-clang-debug"],
			"cacheVariables":{
				"EXCLUDED_WARNINGS": "-Wno-unknown-pragmas;-Wno-unqualified-std-cast-call;-Wno-missing-field-initializers;-Wno-dollar-in-identifier-extension;-Wno-nullability-extension"
			}
		}
	],
	"buildPresets": [
		{
			"name": "linux-debug",
			"description": "",
			"displayName": "",
			"configurePreset": "linux-debug"
		}
	],
	"testPresets": [
		{
			"name": "linux-debug",
			"description": "",
			"displayName": "",
			"configurePreset": "linux-debug"
		}
	]
}